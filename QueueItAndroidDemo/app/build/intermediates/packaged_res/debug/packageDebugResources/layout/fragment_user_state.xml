<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_grouped">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Section header: Current Shared Preferences -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CURRENT SHARED PREFERENCES"
            android:textSize="12sp"
            android:textColor="@color/queueit_green"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="8dp"
            android:paddingStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <!-- Dynamically populated by UserStateFragment -->
            <TableLayout
                android:id="@+id/table_prefs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:stretchColumns="1" />

        </androidx.cardview.widget.CardView>

        <!-- Actions section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACTIONS"
            android:textSize="12sp"
            android:textColor="@color/queueit_green"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <Button
                    android:id="@+id/btn_clear_prefs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🗑  Clear Queue Token"
                    android:backgroundTint="#FFE5E5"
                    android:textColor="#CC0000"
                    android:layout_marginBottom="4dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

                <Button
                    android:id="@+id/btn_clear_cookies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌐  Clear Cookies (WebView)"
                    android:backgroundTint="#FFE5E5"
                    android:textColor="#CC0000"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
